# Copy this file to .env.local (for local dev) or .env and fill in your values.
# Create React App only exposes env vars prefixed with REACT_APP_. Restart dev server after changes.

# Asgardeo application details
REACT_APP_ASGARDEO_CLIENT_ID=lwGgwFMsB86wdJlPLHUmmteWZf0a
# e.g. https://api.asgardeo.io/t/<org_name>
REACT_APP_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/jayathunga
# Comma-separated scopes
REACT_APP_ASGARDEO_SCOPES=openid,profile

# Dev server port. If you change this, update the Asgardeo URLs too.
PORT=3000

# Redirect URLs must EXACTLY match what's configured in Asgardeo Console for the app
# Local defaults for CRA dev server on port 3000 (CRA may auto-increment if busy)
REACT_APP_SIGN_IN_REDIRECT_URL=http://localhost:3000/
REACT_APP_SIGN_OUT_REDIRECT_URL=http://localhost:3000/
