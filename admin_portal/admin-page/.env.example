# Copy this file to .env.local (for local dev) or .env (for production builds)
# and fill in values for your Asgardeo app and hosting path.

# Required: Asgardeo application details
REACT_APP_ASGARDEO_CLIENT_ID=Hza4f1SMGU1t6SiB8mRGm0jyoTYa
REACT_APP_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/jayathunga

# Optional: Override redirect URLs; default uses window.location.origin + BASE_PATH
REACT_APP_SIGN_IN_REDIRECT_URL=https://b9852c74-bc78-48f6-9b02-bbd2da8fd972.e1-us-east-azure.choreoapps.dev
REACT_APP_SIGN_OUT_REDIRECT_URL=https://b9852c74-bc78-48f6-9b02-bbd2da8fd972.e1-us-east-azure.choreoapps.dev

# Optional: If hosting under a sub-path (e.g., https://example.com/admin/), set BASE_PATH to 
# that path including trailing slash. Leave blank or "/" if served at root.
