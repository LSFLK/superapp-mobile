# Admin Portal environment variables
# Copy this file to a new .env.* per environment (e.g. .env.development, .env.production)
# Then adjust values accordingly.

# Asgardeo redirect URLs
REACT_APP_SIGN_IN_REDIRECT_URL=http://localhost:3000/
REACT_APP_SIGN_OUT_REDIRECT_URL=http://localhost:3000/

# Example production values (uncomment and change)
