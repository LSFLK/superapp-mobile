# Base path for payslip API (used in production build; dev uses CRA proxy). Example:
# REACT_APP_PAYSLIP_API_BASE=https://<choreo-domain>/gov-superapp/microappbackendprodbranch/v1.0/admin-portal
REACT_APP_PAYSLIP_API_BASE=https://41200aa1-4106-4e6c-babf-311dce37c04a-prod.e1-us-east-azure.choreoapis.dev/gov-superapp/microappbackendprodbranch/v1.0
# Full absolute upload URL override (skips base + /upload composition). Example:
# REACT_APP_PAYSLIP_UPLOAD_URL=https://<choreo-domain>/gov-superapp/microappbackendprodbranch/v1.0/admin-portal/upload
REACT_APP_PAYSLIP_UPLOAD_URL=https://41200aa1-4106-4e6c-babf-311dce37c04a-prod.e1-us-east-azure.choreoapis.dev/gov-superapp/microappbackendprodbranch/v1.0/admin-portal/upload
